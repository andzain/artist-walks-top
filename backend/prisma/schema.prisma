generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Walk {
  id             String    @id @default(cuid())
  experienceSlug String
  startsAt       DateTime
  capacity       Int
  createdAt      DateTime @default(now())

  bookings       Booking[]
}

model Booking {
  id        String   @id @default(cuid())
  name      String
  email     String

  walkId    String
  walk      Walk @relation(fields: [walkId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}