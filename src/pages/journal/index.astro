---
import BaseLayout from "@layouts/BaseLayout.astro";
import Section from "@components/ui/Section.astro";
import Heading from "@components/ui/Heading.astro";
---

<BaseLayout
  title="Journal"
  description="Essays, photography and stories from ArtistWalks."
>
  <Section>
    <Heading level={1}>Journal</Heading>

    <p class="mt-6 max-w-2xl text-lg text-stone-600">
      Articles, photographs and essays documenting Yerevan's urban life,
      architecture and artistic culture.
    </p>
  </Section>
</BaseLayout>
