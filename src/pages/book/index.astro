---
import { getCollection } from "astro:content";
import { prisma } from "../../lib/prisma";
import BaseLayout from "@layouts/BaseLayout.astro";
import Section from "@components/ui/Section.astro";
import Heading from "@components/ui/Heading.astro";
import BookingForm from "@components/BookingForm.svelte";

const experiences = (await getCollection("experiences")).sort(
  (a, b) => a.data.order - b.data.order,
);

const upcomingWalks = await prisma.walk.findMany({
  where: { startsAt: { gte: new Date() } },
  orderBy: { startsAt: "asc" },
  include: {
    _count: { select: { bookings: true } },
  },
});

const walksBySlug: Record<string, typeof upcomingWalks> = {};
for (const walk of upcomingWalks) {
  (walksBySlug[walk.experienceSlug] ??= []).push(walk);
}
---

<BaseLayout
  title="Book a Walk"
  description="Book an artist-led walking experience in Yerevan."
>
  <Section>
    <Heading level={1}>Book a Walk</Heading>
    <p class="mt-4 max-w-2xl text-lg text-stone-600">
      Choose your experience and reserve your place.
    </p>

    <div class="mt-10 flex flex-col gap-6">
      {
        experiences.map((experience) => (
          <article class="flex gap-0 overflow-hidden rounded-2xl border border-stone-200 bg-white">
            <div class="w-40 shrink-0 sm:w-56">
              <img
                src={experience.data.hero}
                alt={experience.data.title}
                class="h-full w-full object-cover"
              />
            </div>

            <div class="flex flex-1 flex-col justify-between p-6">
              <div>
                <p class="text-xs uppercase tracking-widest text-stone-400">
                  {experience.data.category}
                </p>
                <h2 class="mt-1 text-xl font-semibold text-stone-900">
                  {experience.data.title}
                </h2>
                <p class="mt-2 line-clamp-2 text-sm text-stone-500">
                  {experience.data.description}
                </p>

                <dl class="mt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm">
                  <div>
                    <dt class="text-xs text-stone-400">Duration</dt>
                    <dd class="font-medium text-stone-700">
                      {experience.data.duration}
                    </dd>
                  </div>
                  {experience.data.pricing.perPerson && (
                    <div>
                      <dt class="text-xs text-stone-400">Per person</dt>
                      <dd class="font-medium text-stone-700">
                        €{experience.data.pricing.perPerson}
                      </dd>
                    </div>
                  )}
                  {experience.data.pricing.privateGroup && (
                    <div>
                      <dt class="text-xs text-stone-400">Private group</dt>
                      <dd class="font-medium text-stone-700">
                        €{experience.data.pricing.privateGroup}
                      </dd>
                    </div>
                  )}
                  <div>
                    <dt class="text-xs text-stone-400">Group size</dt>
                    <dd class="font-medium text-stone-700">Up to 8</dd>
                  </div>
                </dl>
              </div>

              <div class="mt-6">
                <BookingForm
                  client:load
                  walks={(
                    walksBySlug[experience.data.experienceSlug] ?? []
                  ).map((w) => ({
                    id: w.id,
                    startsAt: w.startsAt.toISOString(),
                    seatsRemaining: w.capacity - w._count.bookings,
                  }))}
                  experienceTitle={experience.data.title}
                  meetingPoint={experience.data.meetingPoint}
                />
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </Section>
</BaseLayout>
