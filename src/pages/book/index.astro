---
import { getCollection } from "astro:content";

import { prisma } from "../../lib/prisma";

import BaseLayout from "@layouts/BaseLayout.astro";
import Section from "@components/ui/Section.astro";
import Heading from "@components/ui/Heading.astro";
import BookingForm from "@components/BookingForm.svelte";

const experiences = await getCollection("experiences");

const walks = await prisma.walk.findMany({
  include: {
    bookings: true,
  },
});

const bookingCards = experiences
  .map((experience) => {
    const walk = walks.find((item) => item.experienceSlug === experience.id);

    if (!walk) {
      return null;
    }

    return {
      id: experience.id,
      title: experience.data.title,
      description: experience.data.description,
      walk,
    };
  })
  .filter(Boolean);
---

<BaseLayout
  title="Book a Walk"
  description="Book an artist-led walking experience in Yerevan."
>
  <Section>
    <Heading level={1}> Book a Walk </Heading>

    <p class="mt-4 max-w-2xl text-lg text-stone-600">
      Choose your experience and reserve your place.
    </p>

    {
      bookingCards.length > 0 ? (
        <div class="mt-10 grid gap-6 md:grid-cols-2">
          {bookingCards.map((card) => (
            <article class="rounded-2xl border border-stone-200 bg-white p-6">
              <h2 class="text-xl font-semibold text-stone-900">{card.title}</h2>

              <p class="mt-3 text-stone-600">{card.description}</p>

              <div class="mt-5 space-y-2 text-sm text-stone-500">
                <p>Date: {card.walk.startsAt.toLocaleDateString()}</p>

                <p>
                  Available: {card.walk.capacity - card.walk.bookings.length}{" "}
                  places
                </p>
              </div>

              <div class="mt-6">
                <BookingForm client:load walkId={card.walk.id} />
              </div>
            </article>
          ))}
        </div>
      ) : (
        <p class="mt-10 text-stone-500">No walks are currently available.</p>
      )
    }
  </Section>
</BaseLayout>
