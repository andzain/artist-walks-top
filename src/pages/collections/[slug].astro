---
import { getCollection, render } from "astro:content";

import BaseLayout from "@layouts/BaseLayout.astro";
import Section from "@components/ui/Section.astro";
import Heading from "@components/ui/Heading.astro";
import Button from "@components/ui/Button.astro";

const slug = Astro.params.slug!;

const collectionEntries = await getCollection("collections");

const collection = collectionEntries.find((c) => c.id === slug);

if (!collection) {
  throw new Error(`Collection "${slug}" not found`);
}

const { Content } = await render(collection);

const {
  title,
  description,
  hero,
  gallery = [],
  relatedExperience,
} = collection.data;
---

<BaseLayout title={title} description={description} image={hero}>
  <Section>
    <Heading level={1}>{title}</Heading>
    <img src={hero} alt={title} class="mt-6 w-full rounded-2xl object-cover" />
    <div class="prose mt-8">
      <Content />
    </div>
    {
      gallery.length > 0 && (
        <div class="mt-8 grid grid-cols-2 gap-4 md:grid-cols-3">
          {gallery.map((src) => (
            <img src={src} alt={title} class="rounded-xl object-cover" />
          ))}
        </div>
      )
    }
    <div class="mt-8">
      <Button href={`/experiences/${relatedExperience}`}>Related Walk</Button>
    </div>
  </Section>
</BaseLayout>
