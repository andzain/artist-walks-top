---
interface Props {
  title: string;
  description: string;
  category: string;
  duration: string;
  price: number;
  hero: string;
  slug: string;
}

const { title, description, category, duration, price, hero, slug } =
  Astro.props;
---

<article
  class="overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm transition hover:shadow-lg"
>
  <img src={hero} alt={title} class="aspect-[4/3] w-full object-cover" />

  <div class="p-6">
    <p class="text-sm uppercase tracking-wide text-stone-500">
      {category}
    </p>

    <h2 class="mt-2 text-2xl font-semibold">
      {title}
    </h2>

    <p class="mt-4 text-stone-600">
      {description}
    </p>

    <div class="mt-6 flex justify-between text-sm text-stone-500">
      <span>{duration}</span>

      <span>From ${price}</span>
    </div>

    <a
      href={`/experiences/${slug}`}
      class="mt-6 inline-block font-medium underline"
    >
      View Experience →
    </a>
  </div>
</article>
